[workspace]
members = [
    "crates/claude-agent-core",
    "crates/claude-agent-types",
    "crates/claude-agent-mcp",
    "crates/claude-agent-skills",
    "crates/claude-agent-macros",
]
resolver = "2"

[workspace.package]
version = "0.6.0"
authors = ["Tyr Chen <tyr.chen@gmail.com>"]
edition = "2021"
rust-version = "1.90"
license = "MIT"
repository = "https://github.com/tyrchen/claude-agent-sdk-rs"
homepage = "https://github.com/tyrchen/claude-agent-sdk-rs"

[workspace.dependencies]
# Async runtime
tokio = { version = "1.48", features = [
  "macros",
  "rt-multi-thread",
  "process",
  "io-util",
  "sync",
  "time",
] }

# Async traits
async-trait = "0.1"
futures = "0.3"
pin-project = "1.1"
async-stream = "0.3"

# Serialization
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"

# Error handling
thiserror = "2.0"
anyhow = "1.0"

# Path utilities
path-absolutize = "3.1"

# Logging
tracing = "0.1"

# UUID generation
uuid = { version = "1.19", features = ["v4"] }
typed-builder = "0.23.2"

# Macro utilities
paste = "1.0"

# Internal dependencies
claude-agent-core = { path = "crates/claude-agent-core" }
claude-agent-types = { path = "crates/claude-agent-types" }
claude-agent-mcp = { path = "crates/claude-agent-mcp" }
claude-agent-skills = { path = "crates/claude-agent-skills" }
claude-agent-macros = { path = "crates/claude-agent-macros" }
